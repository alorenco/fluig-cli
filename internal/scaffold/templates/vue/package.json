{
  "name": "[[.Code]]",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "watch": "vite build --watch",
    "build": "vue-tsc --noEmit && vite build",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
[[- if .Vuetify]]
    "@mdi/font": "^7",
[[- end]]
    "vue": "^3"[[if .Vuetify]],
    "vuetify": "^3"[[end]]
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6",
    "typescript": "^5",
    "vite": "^7",
[[- if .Vuetify]]
    "vite-plugin-vuetify": "^2",
[[- end]]
    "vue-tsc": "^3"
  }
}
